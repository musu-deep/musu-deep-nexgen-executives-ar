{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix frontend run build",
  "installCommand": "npm --prefix frontend install --legacy-peer-deps",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60
    },
    "api/auth/login.js": {
      "maxDuration": 30
    },
    "api/auth/me.js": {
      "maxDuration": 30
    },
    "api/auth/finance-login.js": {
      "maxDuration": 30
    },
    "api/auth/group-accounts.js": {
      "maxDuration": 30
    },
    "api/auth/otp/request.js": {
      "maxDuration": 30
    },
    "api/auth/otp/verify.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix frontend run build",
  "installCommand": "npm --prefix frontend install --legacy-peer-deps",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 60
    },
    "api/login.js": {
      "maxDuration": 30
    },
    "api/me.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/auth/login", "destination": "/api/login" },
    { "source": "/api/auth/me", "destination": "/api/me" },
    { "source": "/api/:path*", "destination": "/api/[...path]" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
